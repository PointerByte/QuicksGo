{
  "jwt": {
    "enable": true,
    "transport": "header",
    "algorithm": "HS256",
    "hmac": {
      "secret": "replace-with-your-hmac-secret"
    },
    "rsa": {
      "private_key": "./certs/jwt/key.pem",
      "public_key": "./certs/jwt/public.pem"
    },
    "eddsa": {
      "private_key": "./certs/jwt/ed25519-key.pem",
      "public_key": "./certs/jwt/ed25519-public.pem"
    }
  }
}
