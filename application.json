{
    "service": {
        "name": "service-template",
        "version": "0.0.1"
    },
    "server": {
        "gin.mode": "release",
        "api.name": "microservice-template",
        "jwt.active": false,
        "port": ":8080",
        "expectedHosts": ["0.0.0.0:8080", "localhost:8080"],
        "basePaths": ["/service-template/v1"]
    },
    "logger": {
        "dir": "logs",
        "dateFormat": "2006-01-02T15:04:05.000Z",
        "MaxSizeMB": 20,
        "MaxBackups": 3,
        "MaxAgeDays": 28,
        "Compress": true
    },
    "otlp": {
        "enable": false,
        "tls": {
            "insegure": true,
            "mTLS": {
                "enable": false,
                "clientCertPath": "",
                "clientKeyPath": ""
            },
            "caPath": ""
        }
    }
}