{
    "service": {
        "name": "service-template",
        "version": "0.0.1"
    },
    "server": {
        "gin": {
            "UseH2C": false,
            "gzip": {
                "enable": true,
                "excludedExtensions": [".png", ".jpg", ".jpeg", ".gif", ".mp4", ".webm", ".zip", ".gz", ".rar", ".pdf", ".woff2", ".wasm", ".br", ".js.br", ".js.gz"],
                "excludedPaths": ["/status"]
            },
            "mode": "release",
            "ratelimit": 1000,
            "bursts": 2000
        },
        "api.name": "microservice-template",
        "port": ":8080",
        "expectedHosts": ["0.0.0.0:8080", "localhost:8080"],
        "basePaths": ["/service-template/v1"]
    },
    "logger": {
        "dir": "logs",
        "dateFormat": "2006-01-02T15:04:05.000Z",
        "MaxSizeMB": 20,
        "MaxBackups": 3,
        "MaxAgeDays": 28,
        "Compress": true
    },
    "otlp": {
        "enable": false,
        "tls": {
            "insegure": true,
            "mTLS": {
                "enable": false,
                "clientCertPath": "",
                "clientKeyPath": ""
            },
            "caPath": ""
        }
    }
}